{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@pavane/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
